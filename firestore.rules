rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Launch-list signup form (pages/launch-list.html -> assets/js/launch-list-firebase.js).
    // Client is only ever allowed to create a new signup document — never
    // read, update, or delete. Every field is type- and length-checked to
    // match the client-side constraints on the form.
    match /launchListSignups/{signupId} {
      allow read, update, delete: if false;

      allow create: if
        request.resource.data.keys().hasOnly(['fullName', 'phone', 'place', 'submittedAt']) &&
        request.resource.data.keys().hasAll(['fullName', 'phone', 'place', 'submittedAt']) &&

        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() > 0 &&
        request.resource.data.fullName.size() <= 64 &&
        request.resource.data.fullName.matches('^[a-zA-Z ]+$') &&

        request.resource.data.phone is string &&
        request.resource.data.phone.matches('^[0-9]{10}$') &&

        request.resource.data.place is string &&
        request.resource.data.place.size() > 0 &&
        request.resource.data.place.size() <= 64 &&
        request.resource.data.place.matches('^[a-zA-Z ]+$') &&

        // serverTimestamp() resolves to request.time on the server; this
        // rejects any client-supplied literal timestamp.
        request.resource.data.submittedAt == request.time;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
